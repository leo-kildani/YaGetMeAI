# ---------------------------------------------------------------------------
# TransMate – copy to .env and fill in your values. Do not commit .env.
# ---------------------------------------------------------------------------

# Twilio (voice calls, webhooks)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
RECIPIENT_PHONE_NUMBER=

# Languages: caller speaks CALLER_LANGUAGE; recipient hears RECIPIENT_LANGUAGE
# USE_AUTO=true enables automatic language detection for the caller
CALLER_LANGUAGE=es
RECIPIENT_LANGUAGE=en
USE_AUTO=true

# NVIDIA (ASR – speech recognition). Use one of the two function ID vars.
NVIDIA_API_KEY=
NVIDIA_ASR_FUNCTION_ID=
# NVIDIA_ASR_MODEL_FUNCTION_ID=
# NVIDIA_ASR_SERVER=grpc.nvcf.nvidia.com:443

# ElevenLabs (TTS). Use ELEVENLABS_API_KEY or ELEVENLABS_API.
ELEVENLABS_API_KEY=
# ELEVENLABS_API=
ELEVENLABS_ENGLISH_VOICE_ID=
ELEVENLABS_SPANISH_VOICE_ID=
ELEVENLABS_ARABIC_VOICE_ID=
ELEVENLABS_VIETNAMESE_VOICE_ID=

# Public URL for Twilio webhooks (e.g. ngrok: https://xxxx.ngrok-free.app)
PUBLIC_URL=localhost:8000

# OpenAI (optional – for call summaries in the dashboard)
OPENAI_API_KEY=
# OPENAI_SUMMARY_MODEL=gpt-4.1-mini

# Optional: CORS origins for dashboard (comma-separated)
# DASHBOARD_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: path for call history JSON
# CALLS_FILE_PATH=data/calls.json
